rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Bookings: public can CREATE with status=ENQUIRY only.
    // Admins can READ only. Updates/deletes go through Cloud Functions (Admin SDK bypasses rules).
    match /bookings/{bookingId} {
      allow create: if request.resource.data.status == 'ENQUIRY'
                    && request.resource.data.totalAmount is number
                    && request.resource.data.totalAmount > 0
                    && request.resource.data.keys().hasAll(['fullName', 'email', 'ref', 'status', 'totalAmount']);
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Enquiries: public can CREATE only. Admins can read. No client updates.
    match /enquiries/{enquiryId} {
      allow create: if request.resource.data.status == 'NEW'
                    && request.resource.data.keys().hasAll(['name', 'email', 'status']);
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Packages: public can read, only admins can write
    match /packages/{packageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Addons: public can read, only admins can write
    match /addons/{addonId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Admin setup flag: only readable by authenticated users, never writable from client
    match /_admin_setup/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Payments: admin read only, writes via Cloud Functions
    match /payments/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
